# Copy to .env and fill in values. .env is gitignored.
#
# Cloudflare R2 (for highlight clip uploads)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=stompers-videos
R2_PUBLIC_BASE=https://pub-27636b574e544724ab8c5d7c7e755a99.r2.dev

# Firestore (service-account JSON path)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/stompers-tracker-firebase-adminsdk.json
FIRESTORE_PROJECT_ID=stompers-tracker

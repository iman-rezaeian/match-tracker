#!/bin/zsh
# Block direct pushes to main. Use --no-verify to override for intentional deploys.

protected_branch="main"
remote="$1"

while read local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == "refs/heads/$protected_branch" ]]; then
    echo "\n⛔  Push to '$protected_branch' blocked — this branch auto-deploys to production."
    echo "   Use a PR to merge into main, or bypass with:  git push --no-verify\n"
    exit 1
  fi
done

exit 0
